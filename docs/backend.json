
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" },
        "pinnedExams": { "type": "array", "items": { "type": "string" } },
        "deviceCount": { "type": "number" }
      },
      "required": ["id", "name", "email", "phone", "role"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Student issue report and admin resolution node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string", "enum": ["PAYMENT", "PASS", "MOCK_TEST", "TECHNICAL", "ACCOUNT", "OTHER"] },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN", "IN_PROGRESS", "RESOLVED", "CLOSED"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "adminReply": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "HelpArticle": {
      "title": "Help Article",
      "description": "Self-service knowledge base article.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["PAYMENTS", "PASS", "PWA", "TECHNICAL", "ACCOUNT"] },
        "content": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/support_tickets/{ticketId}": {
      "schema": { "$ref": "#/backend/entities/SupportTicket" }
    },
    "/help_articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/HelpArticle" }
    }
  }
}
