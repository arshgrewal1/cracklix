
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Exam": {
      "title": "Exam Vertical",
      "description": "A recruitment hub (e.g., PSSSB Patwari).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "boardId": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "totalFullMocks": { "type": "number" },
        "totalSubjects": { "type": "number" },
        "totalPyqs": { "type": "number" },
        "totalSectional": { "type": "number" },
        "iconUrl": { "type": "string" }
      }
    },
    "Pass": {
      "title": "Institutional Pass",
      "description": "A tiered access node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationDays": { "type": "number" },
        "allowedExams": { "type": "array", "items": { "type": "string" } },
        "promotionBannerUrl": { "type": "string" },
        "active": { "type": "boolean" }
      }
    },
    "Subscription": {
      "title": "User Subscription",
      "description": "Ledger of pass purchases.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "passId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "EXPIRED"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "purchaseDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/backend/entities/Exam" }
    },
    "/passes/{passId}": {
      "schema": { "$ref": "#/backend/entities/Pass" }
    },
    "/subscriptions/{subId}": {
      "schema": { "$ref": "#/backend/entities/Subscription" }
    }
  }
}
