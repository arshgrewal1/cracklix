
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and membership status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pro", "Free"] }
      },
      "required": ["id", "name", "email"]
    },
    "Board": {
      "title": "Recruitment Board",
      "description": "Official government boards (e.g., PSSSB, PPSC).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "abbreviation": { "type": "string" },
        "description": { "type": "string" },
        "iconUrl": { "type": "string" }
      }
    },
    "Exam": {
      "title": "Exam Category",
      "description": "Specific recruitment exams like Patwari or Constable.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "boardId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "totalMocks": { "type": "number" },
        "activeQuestions": { "type": "number" }
      }
    },
    "Subject": {
      "title": "Subject",
      "description": "Study subjects like Punjab GK, Reasoning, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "A full-length or sectional practice test.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "title": { "type": "string" },
        "duration": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "questionIds": { "type": "array", "items": { "type": "string" } },
        "attempts": { "type": "number" }
      }
    },
    "Question": {
      "title": "Question Bank",
      "description": "Individual MCQ for the database.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "explanation": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "topic": { "type": "string" }
      }
    },
    "AttemptResult": {
      "title": "Attempt Result",
      "description": "User results and analytics for a mock attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "weakTopics": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration.",
      "type": "object",
      "properties": {
        "heroLine1": { "type": "string" },
        "heroLine2": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroPrimaryBtn": { "type": "string" },
        "heroSecondaryBtn": { "type": "string" },
        "heroImageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student profiles."
    },
    "/boards/{boardId}": {
      "schema": { "$ref": "#/backend/entities/Board" },
      "description": "Recruitment boards."
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/backend/entities/Exam" },
      "description": "Exam categories."
    },
    "/subjects/{subjectId}": {
      "schema": { "$ref": "#/backend/entities/Subject" },
      "description": "Exam subjects."
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "#/backend/entities/Question" },
      "description": "Global question bank."
    },
    "/mocks/{mockId}": {
      "schema": { "$ref": "#/backend/entities/MockTest" },
      "description": "Mock tests series."
    },
    "/results/{resultId}": {
      "schema": { "$ref": "#/backend/entities/AttemptResult" },
      "description": "User test results."
    },
    "/settings/global": {
      "schema": { "$ref": "#/backend/entities/SiteSettings" },
      "description": "Global site settings."
    }
  }
}
