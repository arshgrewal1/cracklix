
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" },
        "referralCount": { "type": "number" },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Pass": {
      "title": "Institutional Pass",
      "description": "A dynamic access tier created by admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationDays": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "displayOrder": { "type": "number" },
        "recommended": { "type": "boolean" },
        "adFree": { "type": "boolean" },
        "type": { "type": "string", "enum": ["FREE", "PREMIUM"] },
        "description": { "type": "string" }
      }
    },
    "Advertisement": {
      "title": "Advertisement",
      "description": "Campaign management for monetization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["ADSENSE", "BANNER", "HTML", "AFFILIATE"] },
        "status": { "type": "string", "enum": ["ACTIVE", "PAUSED", "SCHEDULED"] },
        "placements": { "type": "array", "items": { "type": "string" } },
        "desktopImageUrl": { "type": "string" },
        "mobileImageUrl": { "type": "string" },
        "externalUrl": { "type": "string" },
        "htmlCode": { "type": "string" },
        "adSenseCode": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "number" },
        "targeting": {
           "type": "object",
           "properties": {
              "regions": { "type": "array", "items": { "type": "string" } },
              "examIds": { "type": "array", "items": { "type": "string" } },
              "categories": { "type": "array", "items": { "type": "string" } }
           }
        },
        "stats": {
           "type": "object",
           "properties": {
              "impressions": { "type": "number" },
              "clicks": { "type": "number" }
           }
        }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student and Admin profiles."
    },
    "/passes/{passId}": {
      "schema": { "$ref": "#/backend/entities/Pass" },
      "description": "Dynamic pricing tiers."
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/backend/entities/Advertisement" },
      "description": "Ad campaigns."
    }
  }
}
