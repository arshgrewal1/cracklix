{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and membership status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Primary recruitment exam metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "board": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "iconUrl": { "type": "string" },
        "totalQuestions": { "type": "number" },
        "duration": { "type": "number" }
      }
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "A specific mock test belonging to an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "title": { "type": "string" },
        "questions": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/MockQuestion" }
        }
      }
    },
    "MockQuestion": {
      "title": "Mock Question",
      "description": "Individual exam question.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number", "description": "0-indexed index of the correct option" },
        "explanation": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] }
      }
    },
    "AttemptResult": {
      "title": "Attempt Result",
      "description": "Analytics from a user's mock attempt.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mockId": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "rank": { "type": "number" },
        "weakTopics": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration including Hero content.",
      "type": "object",
      "properties": {
        "heroLine1": { "type": "string" },
        "heroLine2": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroPrimaryBtn": { "type": "string" },
        "heroSecondaryBtn": { "type": "string" },
        "heroImageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/exams/{examId}": {
      "schema": { "$ref": "#/backend/entities/Exam" },
      "description": "Exam boards and categories."
    },
    "/exams/{examId}/mocks/{mockId}": {
      "schema": { "$ref": "#/backend/entities/MockTest" },
      "description": "Mock tests within an exam."
    },
    "/attempts/{attemptId}": {
      "schema": { "$ref": "#/backend/entities/AttemptResult" },
      "description": "Global log of mock test attempts."
    },
    "/settings/global": {
      "schema": { "$ref": "#/backend/entities/SiteSettings" },
      "description": "Global site settings document."
    }
  }
}
