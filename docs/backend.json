
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pro", "Free", "Silver", "Gold", "Premium"] },
        "referralCount": { "type": "number" },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Subscription": {
      "title": "Aspirant Subscription",
      "description": "Active pass details for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "startDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Payment Order",
      "description": "Internal transaction logs before verification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ExamPattern": {
      "title": "Exam Pattern",
      "description": "Official question distribution and duration for a specific exam type.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "examName": { "type": "string" },
        "totalQuestions": { "type": "number" },
        "duration": { "type": "number" },
        "negativeMarking": { "type": "boolean" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "count": { "type": "number" },
              "subjectId": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student and Admin profiles."
    },
    "/subscriptions/{subId}": {
      "schema": { "$ref": "#/backend/entities/Subscription" },
      "description": "Active pass records."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Transaction ledger."
    },
    "/exam_patterns/{patternId}": {
      "schema": { "$ref": "#/backend/entities/ExamPattern" },
      "description": "Official question distribution blueprints."
    },
    "/boards/{boardId}": { "schema": "object", "description": "Recruitment boards." },
    "/exams/{examId}": { "schema": "object", "description": "Official exam verticals." },
    "/subjects/{subjectId}": { "schema": "object", "description": "Subject categories." },
    "/mocks/{mockId}": { "schema": "object", "description": "Practice tests." },
    "/questions/{questionId}": { "schema": "object", "description": "MCQ bank." },
    "/current_affairs/{id}": { "schema": "object", "description": "Daily Punjab analysis." },
    "/notifications/{id}": { "schema": "object", "description": "Official recruitment alerts." },
    "/reports/{reportId}": { "schema": "object", "description": "Error reports." },
    "/results/{resultId}": { "schema": "object", "description": "Completed mock outcomes." },
    "/settings/{id}": { "schema": "object", "description": "System config." },
    "/bookmarks/{id}": { "schema": "object", "description": "User saved questions." },
    "/pyqs/{id}": { "schema": "object", "description": "Previous year papers." },
    "/support_tickets/{id}": { "schema": "object", "description": "Support inquiries." },
    "/audit_logs/{id}": { "schema": "object", "description": "Admin activity ledger." }
  }
}
