
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" },
        "referralCount": { "type": "number" },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Pass": {
      "title": "Institutional Pass",
      "description": "A dynamic access tier created by admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationDays": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "displayOrder": { "type": "number" },
        "recommended": { "type": "boolean" },
        "type": { "type": "string", "enum": ["FREE", "PREMIUM"] },
        "description": { "type": "string" }
      }
    },
    "Board": {
      "title": "Recruitment Board",
      "description": "Official Punjab government board node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "abbreviation": { "type": "string" },
        "name": { "type": "string" },
        "iconUrl": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Question": {
      "title": "Atomic MCQ Node",
      "description": "A single reusable practice question.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "boardId": { "type": "string" },
        "subjectId": { "type": "string" },
        "questionEn": { "type": "string" },
        "questionPa": { "type": "string" },
        "correctAnswer": { "type": "string", "enum": ["A", "B", "C", "D"] },
        "explanationEn": { "type": "string" },
        "explanationPa": { "type": "string" },
        "difficulty": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student and Admin profiles."
    },
    "/passes/{passId}": {
      "schema": { "$ref": "#/backend/entities/Pass" },
      "description": "Dynamic pricing tiers."
    },
    "/boards/{boardId}": {
      "schema": { "$ref": "#/backend/entities/Board" },
      "description": "Official Board Registry (PSPCL, PSSSB, etc)."
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "#/backend/entities/Question" },
      "description": "Global Atomic Question Bank."
    },
    "/mocks/{mockId}": {
      "schema": "object",
      "description": "High-fidelity mock series."
    },
    "/results/{resultId}": {
      "schema": "object",
      "description": "Aspirant performance audit trails."
    },
    "/payment_requests/{reqId}": {
      "schema": "object",
      "description": "Pending UPI verifications."
    }
  }
}
