
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" },
        "referralCount": { "type": "number" },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Pass": {
      "title": "Institutional Pass",
      "description": "A dynamic access tier created by admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationDays": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "displayOrder": { "type": "number" },
        "recommended": { "type": "boolean" },
        "type": { "type": "string", "enum": ["FREE", "PREMIUM"] },
        "description": { "type": "string" }
      }
    },
    "Subscription": {
      "title": "Aspirant Subscription",
      "description": "Active pass details for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "passId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "startDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentRequest": {
      "title": "Manual Payment Request",
      "description": "UPI/QR transaction details awaiting admin approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student and Admin profiles."
    },
    "/passes/{passId}": {
      "schema": { "$ref": "#/backend/entities/Pass" },
      "description": "Dynamic pricing tiers."
    },
    "/subscriptions/{subId}": {
      "schema": { "$ref": "#/backend/entities/Subscription" },
      "description": "Active pass records."
    },
    "/payment_requests/{reqId}": {
      "schema": { "$ref": "#/backend/entities/PaymentRequest" },
      "description": "Pending UPI verifications."
    }
  }
}
