
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pro", "Free"] },
        "referralCount": { "type": "number" },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "ContentReport": {
      "title": "Content Report",
      "description": "Aspirant feedback on question accuracy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "type": { "type": "string", "enum": ["WRONG_ANS", "TYPO", "MISSING_DATA", "OTHER"] },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "RESOLVED", "IGNORED"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student and Admin profiles."
    },
    "/boards/{boardId}": {
      "schema": "object",
      "description": "Recruitment boards."
    },
    "/exams/{examId}": {
      "schema": "object",
      "description": "Official exam verticals (Patwari, SI, etc)."
    },
    "/subjects/{subjectId}": {
      "schema": "object",
      "description": "Subject categories for MCQs."
    },
    "/mocks/{mockId}": {
      "schema": "object",
      "description": "Practice tests."
    },
    "/questions/{questionId}": {
      "schema": "object",
      "description": "MCQ bank."
    },
    "/current_affairs/{id}": {
      "schema": "object",
      "description": "Daily Punjab and National analysis articles."
    },
    "/notifications/{id}": {
      "schema": "object",
      "description": "Official recruitment alerts and gazeete notifications."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/backend/entities/ContentReport" },
      "description": "Error reports from students."
    },
    "/test_sessions/{sessionId}": {
      "schema": "object",
      "description": "In-progress mock sessions."
    },
    "/results/{resultId}": {
      "schema": "object",
      "description": "Completed mock outcomes."
    },
    "/settings/{id}": {
      "schema": "object",
      "description": "System config."
    },
    "/bookmarks/{id}": {
      "schema": "object",
      "description": "User saved questions."
    },
    "/pyqs/{id}": {
      "schema": "object",
      "description": "Previous year paper archives."
    },
    "/support_tickets/{id}": {
      "schema": "object",
      "description": "Institutional support inquiries."
    },
    "/audit_logs/{id}": {
      "schema": "object",
      "description": "Admin activity ledger."
    }
  }
}
