
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // CRACKLIX PRODUCTION HARDENING V8
    // Optimized for Role-Based Access and Query Performance

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    function isAdmin() {
      let data = getUserData();
      return data != null && (data.role == 'ADMIN' || data.role == 'SUPER_ADMIN');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Dynamic CMS & Configuration ---
    
    match /settings/{docId} {
      allow read: if true; // Publicly accessible for Hero/Announcements
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /boards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /pyqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      // Split read and write to prevent crashes on missing request.resource
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
