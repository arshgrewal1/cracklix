
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // CRACKLIX PRODUCTION HARDENING V5
    // Institutional Grade Security Rules

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return data != null && (data.role == 'ADMIN' || data.role == 'SUPER_ADMIN');
    }

    // --- Core Schemas ---

    match /users/{userId} {
      // Students can read their own profile. Admins can read all for support.
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Only the user or an admin can update profile data.
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /boards/{docId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      // Questions are readable by authenticated students (to take tests) 
      // but write is strictly for admin/super-admin (IP Protection).
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      // Students only see their own performance metrics. 
      // Listing requires a filter: .where('userId', '==', auth.uid)
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      // Session persistence logic (Auto-Save). 
      // sessionId is typically constructed as {uid}_{mockId}
      allow read, write: if isAuthenticated() && (request.auth.uid in sessionId.split('_') || isAdmin());
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      // Strictly user-owned data
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
