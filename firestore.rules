
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isFounder() {
      return isAuthenticated() && request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }

    function getUserData() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isFounder() || (data != null && (data.role == 'ADMIN' || data.role == 'SUPER_ADMIN'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Global Founder Bypass ---
    match /{document=**} {
      allow read, write: if isFounder();
    }

    // --- Standard Rules ---
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /boards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow get, list: if true; 
      allow write: if isAdmin();
    }

    match /pyqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
