
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // FORCE DEPLOYMENT ID: CRACKLIX_RESOLVE_P110
    // AUTHOR: Arsh Grewal Management
    // TIMESTAMP: 2024-06-02T23:15:00Z
    // PURPOSE: Resolve 'get' operation permissions for global settings.

    // 1. Notifications: Explicitly public for alerts
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Current Affairs: Explicitly public for news updates
    match /current_affairs/{caId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. User Profiles: Privacy-first matching
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Test Results: Owner-only access
    match /results/{resultId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // 5. Platform Settings: Publicly readable for Hero/Branding
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 6. Educational Content: Publicly readable for indexing/catalog
    match /boards/{id} { allow read: if true; allow write: if request.auth != null; }
    match /exams/{id} { allow read: if true; allow write: if request.auth != null; }
    match /subjects/{id} { allow read: if true; allow write: if request.auth != null; }
    match /questions/{id} { allow read: if true; allow write: if request.auth != null; }
    match /mocks/{id} { allow read: if true; allow write: if request.auth != null; }

    // Recursive support for sub-resources if any
    match /boards/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /exams/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /mocks/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
  }
}
