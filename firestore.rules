rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 1. Content Registry ---
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /boards/{boardId} { allow read: if true; allow write: if isAdmin(); }
    match /exams/{examId} { allow read: if true; allow write: if isAdmin(); }
    match /questions/{qId} { allow read: if true; allow write: if isAdmin(); }
    match /mcqBank/{qId} { allow read: if true; allow write: if isAdmin(); }
    match /mocks/{mockId} { allow read: if true; allow write: if isAdmin(); }
    match /daily_quizzes/{quizId} { allow read: if true; allow write: if isAdmin(); }
    match /notes/{noteId} { allow read: if true; allow write: if isAdmin(); }
    match /pyqs/{pyqId} { allow read: if true; allow write: if isAdmin(); }
    match /help_articles/{articleId} { allow read: if true; allow write: if isAdmin(); }
    match /exam_calendar/{eventId} { allow read: if true; allow write: if isAdmin(); }
    match /success_stories/{storyId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{sId} { allow read: if true; allow write: if isAdmin(); }
    match /passes/{pId} { allow read: if true; allow write: if isAdmin(); }
    match /vacancies/{vId} { allow read: if true; allow write: if isAdmin(); }
    match /vacancy_categories/{vId} { allow read: if true; allow write: if isAdmin(); }

    // --- 2. Aspirant Profiles ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && (
        !request.resource.data.diff(request.resource.data).affectedKeys().hasAny(['role', 'passStatus', 'planTier', 'passExpiresAt', 'status'])
      ));
      
      match /study_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 3. Monetization Ledger ---
    match /payment_requests/{reqId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); 
    }
    
    match /subscriptions/{sId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // --- 4. Performance Nodes ---
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && resultId.split('_')[0] == request.auth.uid;
    }
    
    match /attempts/{attemptId} {
      allow read, write: if isAuthenticated() && (attemptId.split('_')[0] == request.auth.uid || isAdmin());
    }

    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /vacancy_analytics/{id} {
      allow read, create, update: if true;
    }
  }
}
