rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview Enterprise RBAC Security Protocol v2.0.
     * Hardened for 10k+ Aspirants with strict ownership and authority gates.
     */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 1. Master Content (Public Read, Admin Write) ---
    match /boards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /questions/{qId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /passes/{passId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /subjects/{sId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{sId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if true; // stats incrementation
    }
    match /notifications/{nId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /free_content/{fcId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /current_affairs/{caId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- 2. Aspirant Data (Private Nodes) ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /attempts/{attemptId} {
      // attemptId format is {userId}_{mockId}
      allow read: if isAuthenticated() && (attemptId.split('_')[0] == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() && attemptId.split('_')[0] == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /bookmarks/{bId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /subscriptions/{sId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // --- 3. Management & Payment Audits ---
    match /payment_requests/{reqId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /payments/{pId} {
      allow read: if isAdmin() || (resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}