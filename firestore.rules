rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 1. Master Content ---
    match /boards/{boardId} { allow read: if true; allow write: if isAdmin(); }
    match /exams/{examId} { allow read: if true; allow write: if isAdmin(); }
    match /questions/{qId} { allow read: if true; allow write: if isAdmin(); }
    match /passes/{passId} { allow read: if true; allow write: if isAdmin(); }
    match /notes/{noteId} { allow read: if true; allow write: if isAdmin(); }
    match /subjects/{sId} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /current_affairs_hub/{caId} { allow read: if true; allow write: if isAdmin(); }
    match /pyqs/{pyqId} { allow read: if true; allow write: if isAdmin(); }
    match /help_articles/{articleId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{sId} { allow read: if true; allow write: if isAdmin(); }

    // --- 2. Student Data ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isOwner(userId) && (
        // Protect sensitive fields from self-modification
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'pass', 'passStatus', 'planTier', 'passExpiresAt', 'status'])
      ));
    }

    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status);
    }

    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (attemptId.split('_')[0] == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() && attemptId.split('_')[0] == request.auth.uid;
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resultId.split('_')[0] == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resultId.split('_')[0] == request.auth.uid);
    }

    match /bookmarks/{bId} {
      allow read, write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // --- 3. Monetization ---
    match /payment_requests/{reqId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
    match /subscriptions/{sId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
