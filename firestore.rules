
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isFounder() {
      return isAuthenticated() && request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }

    function isAdmin() {
      return isFounder() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN']
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Public Institutional Data ---
    match /boards/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /exams/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /subjects/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /mocks/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /current_affairs/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /notifications/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /pyqs/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /notes/{docId} { allow read: if true; allow write: if isAdmin(); }

    // --- Protected Aspirant Data ---
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
    }

    match /bookmarks/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isFounder();
    }
  }
}
