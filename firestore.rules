
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // FORCE DEPLOYMENT ID: CRACKLIX_SYNC_v105
    // AUTHOR: Arsh Grewal Management
    // TIMESTAMP: 2024-06-02T20:15:00Z

    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Profiles: Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Content Collections: Explicitly allowing global READ (get and list) 
    // for all public-facing content.
    
    match /boards/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /exams/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /subjects/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /questions/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /mocks/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /current_affairs/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /notifications/{document=**} { allow read: if true; allow write: if isAuthenticated(); }
    match /settings/{document=**} { allow read: if true; allow write: if isAuthenticated(); }

    // Results: Users can only read/write their own results
    match /results/{id} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource == null || (resource.data != null && resource.data.userId == request.auth.uid));
    }
  }
}
