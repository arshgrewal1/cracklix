
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // FORCE DEPLOYMENT ID: CRACKLIX_PRODUCTION_HARDENING_V3
    // AUTHOR: Arsh Grewal Institutional Management

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'ADMIN' ||
        getUserData().role == 'SUPER_ADMIN'
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /boards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow delete, update: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in sessionId || isAdmin());
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read, write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
