
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // CRACKLIX PRODUCTION HARDENING V6
    // Institutional Grade Security Rules

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return data != null && (data.role == 'ADMIN' || data.role == 'SUPER_ADMIN');
    }

    // --- Core Schemas ---

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /boards/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /pyqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /test_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in sessionId.split('_') || isAdmin());
    }

    match /current_affairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /bookmarks/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
