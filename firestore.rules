
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEV MODE: Unrestricted access to all collections to facilitate rapid development and content seeding.
    // This resolves permission errors for current_affairs, notifications, mocks, etc.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
