
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // FORCE DEPLOYMENT ID: CRACKLIX_FINAL_SYNC_v107
    // AUTHOR: Arsh Grewal Management
    // TIMESTAMP: 2024-06-02T20:25:00Z

    // Profiles: Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Results: Users can only read their own results
    match /results/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Public Content: Boards, Exams, Subjects, Questions, Mocks, Current Affairs, Notifications
    // Explicitly allow both get and list for public visibility.
    match /boards/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /exams/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /subjects/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /questions/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /mocks/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /current_affairs/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /notifications/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
    match /settings/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
  }
}
