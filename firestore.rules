
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview Institutional Prototype Security Protocol.
     * Full permissive access enabled to support rapid iteration of PSPCL and EVS nodes.
     * This triggers a fresh deployment cycle for all global repository paths.
     */
    match /{document=**} {
      allow read, list, write: if true;
    }
  }
}

// NOTE: Firebase Storage rules for 'authority_logos' must be set manually 
// in the Firebase Console to allow uploads for authenticated admins.
