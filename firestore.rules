rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. CORE HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuspended() {
      return getUserData().status == 'SUSPENDED';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'SUPER_ADMIN';
    }

    function hasPermission(perm) {
      return isAuthenticated() && 
             !isSuspended() && 
             (getUserData().role == 'SUPER_ADMIN' || getUserData().permissions[perm] == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 2. USER REGISTRY ---

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only Super Admin can change roles or permissions
      allow create: if isAuthenticated() && (isSuperAdmin() || isOwner(userId));
      allow update: if isSuperAdmin() || (isOwner(userId) && 
                      !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'permissions', 'status']));
    }

    // --- 3. CONTENT PERMISSIONS ---

    match /categories/{id} { allow read: if true; allow write: if hasPermission('manageCategories'); }
    match /boards/{id} { allow read: if true; allow write: if hasPermission('manageCategories'); }
    match /exams/{id} { allow read: if true; allow write: if hasPermission('manageCategories'); }
    
    match /subjects/{id} { 
      allow read: if true; 
      allow create: if hasPermission('createSubject');
      allow update: if hasPermission('editSubject');
      allow delete: if hasPermission('deleteSubject');
    }

    match /test_series/{id} {
      allow read: if true;
      allow write: if hasPermission('manageSeries');
    }

    match /mocks/{id} {
      allow read: if true;
      allow create: if hasPermission('createMock');
      allow update: if hasPermission('editMock');
      allow delete: if hasPermission('deleteMock');
    }

    match /mcqBank/{id} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('uploadQuestions');
      allow update: if hasPermission('editQuestions');
      allow delete: if hasPermission('deleteQuestions');
    }

    match /questions/{id} {
      allow read: if true;
      allow create: if hasPermission('uploadQuestions');
      allow update: if hasPermission('editQuestions');
      allow delete: if hasPermission('deleteQuestions');
    }

    match /pyqs/{id} {
      allow read: if true;
      allow create: if hasPermission('uploadPYQs');
      allow update: if hasPermission('editPYQs');
      allow delete: if hasPermission('deletePYQs');
    }

    // --- 4. SYSTEM & FINANCIALS ---

    match /payment_requests/{id} {
      allow create: if isAuthenticated();
      allow read: if hasPermission('managePayments') || resource.data.userId == request.auth.uid;
      allow update: if hasPermission('managePayments');
    }

    match /subscriptions/{id} {
      allow read: if hasPermission('viewRevenue') || resource.data.userId == request.auth.uid;
      allow write: if hasPermission('managePayments');
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if hasPermission('websiteSettings');
    }

    match /audit_logs/{id} {
      allow read: if hasPermission('manageRoles');
      allow create: if isAuthenticated();
    }
  }
}