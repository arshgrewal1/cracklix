
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * @fileOverview Institutional Security Rules (Phase 155).
     * DEV MODE: Global read/write access enabled for rapid prototyping and content seeding.
     * Ensure these are hardened before moving to a public production environment.
     * 
     * DEPLOYMENT_AUDIT_ID: 2026-06-03T09:05:00Z
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit collection access for visibility in logs
    match /mocks/{id} {
      allow read, write: if true;
    }
    
    match /users/{id} {
      allow read, write: if true;
    }

    match /current_affairs/{id} {
      allow read, write: if true;
    }

    match /notifications/{id} {
      allow read, write: if true;
    }
  }
}
