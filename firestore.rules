
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Institutional Prototype Protocol: Full permissive access for rapid iteration.
    // Triggering fresh deployment cycle for updated PSPCL and EVS nodes.
    match /{document=**} {
      allow read, list, write: if true;
    }
  }
}

// NOTE: Firebase Storage rules should be updated in the Firebase Console
// to allow the 'authority_logos' path for authenticated users.
