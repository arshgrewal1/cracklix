rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview TOTAL AUTHORITY NODE (SYNC 500).
     * This rule set explicitly grants global access to all 16 institutional collections.
     * 
     * DEPLOYMENT_ID: 2026-06-03T18:30:00Z
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit Paths for Audit Node Visibility & List Operations
    match /users/{id} { allow read, write: if true; }
    match /boards/{id} { allow read, write: if true; }
    match /exams/{id} { allow read, write: if true; }
    match /subjects/{id} { allow read, write: if true; }
    match /mocks/{id} { allow read, write: if true; }
    match /questions/{id} { allow read, write: if true; }
    match /current_affairs/{id} { allow read, write: if true; }
    match /notifications/{id} { allow read, write: if true; }
    match /reports/{id} { allow read, write: if true; }
    match /test_sessions/{id} { allow read, write: if true; }
    match /results/{id} { allow read, write: if true; }
    match /settings/{id} { allow read, write: if true; }
    match /bookmarks/{id} { allow read, write: if true; }
    match /pyqs/{id} { allow read, write: if true; }
    match /support_tickets/{id} { allow read, write: if true; }
    match /audit_logs/{id} { allow read, write: if true; }
  }
}